# =============================================================================
# LinkX 后端 · 生产模板（.env.prod.example）
# -----------------------------------------------------------------------------
# 复制为 .env.prod 后填写；.env.prod 已 gitignore
# 或在部署平台注入同名环境变量（优先级更高）
# =============================================================================

# ---------- Profile / 端口 ----------
# 选择加载 .env.prod；对应 yml：spring.profiles.active
SPRING_PROFILES_ACTIVE=prod
# HTTP 端口；对应 yml：server.port
SERVER_PORT=8080

# ---------- JWT ----------
# openssl rand -base64 32；对应 yml：linkx.jwt.secret
JWT_SECRET=
# access 1h；对应 yml：linkx.jwt.access-expire
JWT_ACCESS_EXPIRE=3600000
# refresh 7d；对应 yml：linkx.jwt.refresh-expire
JWT_REFRESH_EXPIRE=604800000

# ---------- MySQL ----------
# SSL JDBC URL；对应 yml：spring.datasource.url
DB_URL=jdbc:mysql://YOUR_DB_HOST:3306/linkx?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=true&requireSSL=true
# 用户名；对应 yml：spring.datasource.username
DB_USERNAME=
# 密码；对应 yml：spring.datasource.password
DB_PASSWORD=

# ---------- Redis ----------
# 主机；对应 yml：spring.data.redis.host
REDIS_HOST=
# 端口；对应 yml：spring.data.redis.port
REDIS_PORT=6379
# 密码；对应 yml：spring.data.redis.password
REDIS_PASSWORD=
# DB；对应 yml：spring.data.redis.database
REDIS_DATABASE=0

# ---------- 上传 ----------
# 单文件；对应 yml：spring.servlet.multipart.max-file-size
MULTIPART_MAX_FILE_SIZE=5MB
# 整次请求；对应 yml：spring.servlet.multipart.max-request-size
MULTIPART_MAX_REQUEST_SIZE=6MB

# ---------- 鉴权 / 安全 ----------
# 验证码；对应 yml：linkx.auth.captcha-enabled
CAPTCHA_ENABLED=true
# HTTPS；对应 yml：linkx.security.require-https
REQUIRE_HTTPS=true
# 反代；对应 yml：linkx.proxy.trust-proxy
TRUST_PROXY=true
# 锁定次数；对应 yml：linkx.auth.login-max-attempts
AUTH_LOGIN_MAX_ATTEMPTS=3
# 锁定分钟；对应 yml：linkx.auth.lock-duration-minutes
AUTH_LOCK_DURATION_MINUTES=30
# 登录限流；对应 yml：linkx.auth.rate-limit-login-per-minute
AUTH_RATE_LIMIT_LOGIN=5
# 注册限流；对应 yml：linkx.auth.rate-limit-register-per-minute
AUTH_RATE_LIMIT_REGISTER=2

# ---------- CORS ----------
# 正式前端域；对应 yml：linkx.cors.allowed-origins
CORS_ALLOWED_ORIGINS=https://app.example.com

# ---------- IM ----------
# WS 端口；对应 yml：linkx.im.websocket-port
IM_WS_PORT=8081

# ---------- MinIO ----------
# HTTPS Endpoint；对应 yml：linkx.minio.endpoint
MINIO_ENDPOINT=https://minio.example.com
# Access Key；对应 yml：linkx.minio.access-key
MINIO_ACCESS_KEY=
# Secret Key；对应 yml：linkx.minio.secret-key
MINIO_SECRET_KEY=
# 桶；对应 yml：linkx.minio.bucket-name
MINIO_BUCKET_NAME=linkx
# 5MB；对应 yml：linkx.minio.max-file-size
MINIO_MAX_FILE_SIZE=5242880
# 头像 12h；对应 yml：linkx.minio.presign-expiry.avatar-seconds
MINIO_PRESIGN_AVATAR_SECONDS=43200
# 文件 30min；对应 yml：linkx.minio.presign-expiry.file-seconds
MINIO_PRESIGN_FILE_SECONDS=1800
# 分享 5min；对应 yml：linkx.minio.presign-expiry.share-seconds
MINIO_PRESIGN_SHARE_SECONDS=300

# ---------- 邮件 ----------
# SMTP；对应 yml：linkx.mail.host
MAIL_HOST=smtp.qq.com
# 端口；对应 yml：linkx.mail.port
MAIL_PORT=587
# 账号；对应 yml：linkx.mail.username
MAIL_USERNAME=
# 授权码；对应 yml：linkx.mail.password
MAIL_PASSWORD=
# 发件人；对应 yml：linkx.mail.from
MAIL_FROM=
# 显示名；对应 yml：linkx.mail.from-name
MAIL_FROM_NAME=LinkX
# STARTTLS；对应 yml：linkx.mail.start-tls
MAIL_START_TLS=true
# SSL；对应 yml：linkx.mail.ssl
MAIL_SSL=false
# 验证码分钟；对应 yml：linkx.mail.code-expire-minutes
MAIL_CODE_EXPIRE_MINUTES=10

# ---------- 应用 / 留存 ----------
# 版本；对应 yml：linkx.app.version
APP_VERSION=1.0.0
# 渠道；对应 yml：linkx.app.channel
APP_CHANNEL=stable
# 说明；对应 yml：linkx.app.release-notes
APP_RELEASE_NOTES=
# 下载；对应 yml：linkx.app.download-url
APP_DOWNLOAD_URL=
# 留存天；对应 yml：linkx.retention.message-days
MESSAGE_RETENTION_DAYS=365

# ---------- 生产安全默认 ----------
# 关 Swagger；对应 yml：springdoc.*.enabled
SPRINGDOC_ENABLED=false
# 仅 health；对应 yml：management.endpoints.web.exposure.include
MANAGEMENT_ENDPOINTS=health
# 无健康细节；对应 yml：management.endpoint.health.show-details
MANAGEMENT_HEALTH_SHOW_DETAILS=never
# 根日志；对应 yml：logging.level.root
LOG_LEVEL_ROOT=INFO
# 业务日志；对应 yml：logging.level.com.linkx.server
LOG_LEVEL_LINKX=INFO
# Security 日志；对应 yml：logging.level.org.springframework.security
LOG_LEVEL_SECURITY=WARN
