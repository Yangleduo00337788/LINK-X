# =============================================================================
# LinkX 后端 · 本地模板（.env.local.example）
# -----------------------------------------------------------------------------
# 复制为 .env.local 后填写真实值；.env.local 已 gitignore
# 字段说明与 .env.local 相同，此处账号密码留空以免误提交
# =============================================================================

# ---------- Profile / 端口 ----------
# 选择加载 .env.local；对应 yml：spring.profiles.active
SPRING_PROFILES_ACTIVE=local
# HTTP API 端口；对应 yml：server.port
SERVER_PORT=8080

# ---------- JWT ----------
# 签名密钥 ≥32 字符；对应 yml：linkx.jwt.secret
JWT_SECRET=dev-local-jwt-secret-change-me-32chars!!
# access 有效期毫秒（2h）；对应 yml：linkx.jwt.access-expire
JWT_ACCESS_EXPIRE=7200000
# refresh 有效期毫秒（7d）；对应 yml：linkx.jwt.refresh-expire
JWT_REFRESH_EXPIRE=604800000

# ---------- MySQL ----------
# 完整 JDBC URL；对应 yml：spring.datasource.url
DB_URL=jdbc:mysql://127.0.0.1:3306/linkx?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false
# 用户名；对应 yml：spring.datasource.username
DB_USERNAME=root
# 密码；对应 yml：spring.datasource.password
DB_PASSWORD=root

# ---------- Redis ----------
# 主机；对应 yml：spring.data.redis.host
REDIS_HOST=127.0.0.1
# 端口；对应 yml：spring.data.redis.port
REDIS_PORT=6379
# 密码（无则留空）；对应 yml：spring.data.redis.password
REDIS_PASSWORD=
# DB 编号；对应 yml：spring.data.redis.database
REDIS_DATABASE=0

# ---------- 上传体积 ----------
# 单文件上限；对应 yml：spring.servlet.multipart.max-file-size
MULTIPART_MAX_FILE_SIZE=100MB
# 整次请求上限；对应 yml：spring.servlet.multipart.max-request-size
MULTIPART_MAX_REQUEST_SIZE=110MB

# ---------- 鉴权 / 安全 ----------
# 图形验证码；对应 yml：linkx.auth.captcha-enabled
CAPTCHA_ENABLED=false
# 强制 HTTPS；对应 yml：linkx.security.require-https
REQUIRE_HTTPS=false
# 信任反代头；对应 yml：linkx.proxy.trust-proxy
TRUST_PROXY=false
# 登录失败锁定次数；对应 yml：linkx.auth.login-max-attempts
AUTH_LOGIN_MAX_ATTEMPTS=5
# 锁定分钟数；对应 yml：linkx.auth.lock-duration-minutes
AUTH_LOCK_DURATION_MINUTES=15
# 登录限流；对应 yml：linkx.auth.rate-limit-login-per-minute
AUTH_RATE_LIMIT_LOGIN=10
# 注册限流；对应 yml：linkx.auth.rate-limit-register-per-minute
AUTH_RATE_LIMIT_REGISTER=5

# ---------- CORS ----------
# 逗号分隔白名单；对应 yml：linkx.cors.allowed-origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- IM ----------
# WebSocket 端口；对应 yml：linkx.im.websocket-port
IM_WS_PORT=8081

# ---------- MinIO ----------
# Endpoint；对应 yml：linkx.minio.endpoint
MINIO_ENDPOINT=http://127.0.0.1:9000
# Access Key；对应 yml：linkx.minio.access-key
MINIO_ACCESS_KEY=minioadmin
# Secret Key；对应 yml：linkx.minio.secret-key
MINIO_SECRET_KEY=minioadmin123
# 桶名；对应 yml：linkx.minio.bucket-name
MINIO_BUCKET_NAME=linkx
# 单文件字节上限；对应 yml：linkx.minio.max-file-size
MINIO_MAX_FILE_SIZE=104857600
# 头像预签名秒数；对应 yml：linkx.minio.presign-expiry.avatar-seconds
MINIO_PRESIGN_AVATAR_SECONDS=86400
# 文件预签名秒数；对应 yml：linkx.minio.presign-expiry.file-seconds
MINIO_PRESIGN_FILE_SECONDS=3600
# 分享预签名秒数；对应 yml：linkx.minio.presign-expiry.share-seconds
MINIO_PRESIGN_SHARE_SECONDS=600

# ---------- 邮件（按需填写）----------
# SMTP 主机；对应 yml：linkx.mail.host
MAIL_HOST=smtp.qq.com
# 端口；对应 yml：linkx.mail.port
MAIL_PORT=587
# 账号；对应 yml：linkx.mail.username
MAIL_USERNAME=
# 授权码；对应 yml：linkx.mail.password
MAIL_PASSWORD=
# 发件人；对应 yml：linkx.mail.from
MAIL_FROM=
# 显示名；对应 yml：linkx.mail.from-name
MAIL_FROM_NAME=LinkX
# STARTTLS；对应 yml：linkx.mail.start-tls
MAIL_START_TLS=true
# SSL；对应 yml：linkx.mail.ssl
MAIL_SSL=false
# 验证码分钟；对应 yml：linkx.mail.code-expire-minutes
MAIL_CODE_EXPIRE_MINUTES=10

# ---------- 应用 / 留存 ----------
# 版本；对应 yml：linkx.app.version
APP_VERSION=1.0.0
# 渠道；对应 yml：linkx.app.channel
APP_CHANNEL=stable
# 更新说明；对应 yml：linkx.app.release-notes
APP_RELEASE_NOTES=本地开发构建
# 下载地址；对应 yml：linkx.app.download-url
APP_DOWNLOAD_URL=
# 消息保留天；对应 yml：linkx.retention.message-days
MESSAGE_RETENTION_DAYS=365

# ---------- Swagger / Actuator / 日志 ----------
# 开启 Swagger；对应 yml：springdoc.*.enabled
SPRINGDOC_ENABLED=true
# Actuator 端点；对应 yml：management.endpoints.web.exposure.include
MANAGEMENT_ENDPOINTS=health,info,metrics,prometheus
# 健康详情；对应 yml：management.endpoint.health.show-details
MANAGEMENT_HEALTH_SHOW_DETAILS=when_authorized
# 根日志；对应 yml：logging.level.root
LOG_LEVEL_ROOT=info
# 业务日志；对应 yml：logging.level.com.linkx.server
LOG_LEVEL_LINKX=debug
# Security 日志；对应 yml：logging.level.org.springframework.security
LOG_LEVEL_SECURITY=WARN
