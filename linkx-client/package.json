{
  "name": "linkx",
  "description": "LinkX — 企业级即时通讯与协同平台桌面客户端",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "vue-tsc --noEmit && vite build --mode electron && electron-builder",
    "electron:preview": "electron dist-electron/main/main.js"
  },
  "dependencies": {
    "@vicons/ionicons5": "^0.12.0",
    "axios": "^1.18.1",
    "naive-ui": "^2.38.2",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "vue": "^3.4.21",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "dompurify": "^3.4.11",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "marked": "^18.0.5",
    "typescript": "^5.4.5",
    "unocss": "^0.59.4",
    "vite": "^5.2.8",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.11"
  },
  "build": {
    "appId": "com.linkx.app",
    "productName": "LinkX",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
