# LinkX 生产环境变量模板（复制后填入真实值，勿提交真实密钥）
# 用法：复制为服务器上的 .env / 注入 CI Secrets / 容器 env

SPRING_PROFILES_ACTIVE=prod

# JWT（openssl rand -base64 32）
JWT_SECRET=

# MySQL
DB_HOST=
DB_PORT=3306
DB_NAME=linkx
DB_USERNAME=
DB_PASSWORD=

# Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO / S3 兼容（须 HTTPS）
MINIO_ENDPOINT=https://minio.example.com
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=linkx

# CORS（前端正式域名）
CORS_ORIGIN_1=https://app.example.com
CORS_ORIGIN_2=

# 邮件（禁止使用仓库 application.yml 中的开发默认值）
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=LinkX

# IM
IM_WS_PORT=8081

# 可选
APP_VERSION=1.0.0
APP_CHANNEL=stable
CAPTCHA_ENABLED=true
REQUIRE_HTTPS=true
